# Flask
SECRET_KEY=change-me-generate-with-python-secrets-token_hex-32
FLASK_ENV=production

# Webhook
# Perry signs incoming requests with HMAC-SHA256 using this secret.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PERRY_WEBHOOK_SECRET=change-me

# Database
DATABASE_PATH=/var/lib/clk-app/config.db

# Network
BIND_HOST=0.0.0.0
BIND_PORT=8080

# RS-485 defaults (can be overridden via web UI)
RS485_PORT=/dev/ttyUSB0
RS485_BAUD=9600
CLOCK_ADDRESS=0x01

# Behavior defaults
DEFAULT_COUNTDOWN_SECONDS=1800
